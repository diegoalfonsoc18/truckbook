{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Start",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start"],
      "port": 8081
    },
    {
      "name": "Expo Go",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--go"],
      "port": 8081
    },
    {
      "name": "Expo Go (clear)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--go", "--clear"],
      "port": 8081
    },
    {
      "name": "Expo Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web"],
      "port": 8081
    },
    {
      "name": "Expo iOS",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "run:ios"],
      "port": 8081
    },
    {
      "name": "Expo Android",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "run:android"],
      "port": 8081
    },
    {
      "name": "Static Assets",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "4599"],
      "port": 4599
    }
  ]
}
